<section class="text-dark-text" data-counter-section>
	{% embed "../layouts/container.twig" %}
		{% block content %}
			{% if fields.title %}
				<div class="mb-8 text-center lg:text-left md:mb-16">
					<h2 class="text-h2 md:text-[40px] lg:text-[32px] leading-tight">{{ fields.title }}</h2>
				</div>
			{% endif %}

			{% if fields.list %}
				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 sm:gap-x-8 lg:gap-0">
					{% for item in fields.list %}
						<div class="flex flex-col items-center text-center gap-2 pb-4 border-b border-[#C7C7C7] lg:pb-0 lg:border-b-0 lg:border-r lg:last:border-r-0 lg:px-6 md:gap-4">
							<div class="text-5xl leading-14 font-medium text-green-default md:text-[64px]" data-counter="{{ item.number }}">0</div>
							<div class="text-body-15 font-semibold text-gray-1 flex items-center justify-center gap-1 md:text-[18px]">
                                {% if item.icon %}
                                    <div class="flex-none">
                                        {{ item.icon|raw }}
                                    </div>
                                {% endif %}
                                {{ item.text }}
                            </div>
						</div>
					{% endfor %}
				</div>
			{% endif %}
		{% endblock %}
	{% endembed %}
</section>
