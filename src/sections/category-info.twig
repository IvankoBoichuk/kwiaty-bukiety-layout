<section>
	{% embed "../layouts/container.twig" %}
		{% block content %}
			<div class="max-w-none prose prose-slate lg:prose-lg">
				{% if info.title %}
					<h1 class="text-h1">
						{{ info.title }}
					</h1>
				{% endif %}

				<div class="prose-p:text-body-13 prose-h2:text-h3">
					{{ info.text | raw }}
				</div>
			</div>
		{% endblock %}
	{% endembed %}
</section>
