<section class="text-dark-text md:pb-10 lg:pb-25">
	{% embed "../layouts/container.twig" %}
		{% block content %}
			{% if fields.title %}

				<div class="mb-6 lg:mb-16">
					<h2 class="text-h2 md:text-[28px] lg:text-[32px]">{{ fields.title }}</h2>
				</div>
			{% endif %}

			{% if fields.list %}
				<div x-data="accordion" class="divide-y divide-[#E0E0D7] lg:border-y lg:border-[#E0E0D7]">
					{% for item in fields.list %}
						<div class="overflow-hidden pb-3 last:pb-0 lg:pb-4">
							<button
								@click="toggle('faq-{{ loop.index }}')"
								class="w-full flex items-center justify-between gap-4 text-left"
								:aria-expanded="isActive('faq-{{ loop.index }}')"
							>
                                <span class="flex items-baseline gap-3 lg:gap-12 min-w-0">
                                    {% if fields.numbered %}
                                        <span class="hidden lg:block shrink-0 w-8 text-[16px] text-gray-3">0{{ loop.index }}</span>
                                    {% endif %}
                                    <span class="text-h3 lg:text-[18px] pr-6.5 lg:pr-0 text-green-default">{{ item.title }}</span>
                                </span>
						<div class="relative size-6 shrink-0">
									<span
										class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-4 h-0.5 bg-dark-text transition-transform duration-300"
										:class="{ 'rotate-0': !isActive('faq-{{ loop.index }}'), 'rotate-180': isActive('faq-{{ loop.index }}') }"
									></span>
									<span
										class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-4 h-0.5 bg-dark-text transition-transform duration-300 origin-center"
										:class="{ 'rotate-90': !isActive('faq-{{ loop.index }}'), 'rotate-0': isActive('faq-{{ loop.index }}') }"
									></span>
								</div>
							</button>

							<div x-show="isActive('faq-{{ loop.index }}')" x-collapse>
								{% if fields.numbered %}
									<div class="grid grid-cols-12 gap-4 pt-2 md:pt-4">
										<div class="hidden lg:block lg:col-span-6"></div>
										<div class="col-span-12 text-body-13 text-green-dark md:text-[16px] lg:col-span-6">
											{{ item.text }}
										</div>
									</div>
								{% else %}
									<div class="pt-2 text-body-13 text-green-dark md:pt-4 md:text-[16px] lg:text-[18px]">
										{{ item.text }}
									</div>
								{% endif %}
							</div>
						</div>
					{% endfor %}
				</div>
			{% endif %}

		{% endblock %}
	{% endembed %}
</section>
