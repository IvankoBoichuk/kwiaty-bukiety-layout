<section class="text-dark-text">
	{% embed "../layouts/container.twig" %}
		{% block content %}
			{% if fields.title %}
				<div class="mb-6 md:mb-8">
					<h2 class="{{ html_classes('text-h2', { 'md:text-[40px] md:leading-tight md:font-bold': fields.numbered }) }}">{{ fields.title }}</h2>
				</div>
			{% endif %}

			{% if fields.list %}
				<div x-data="accordion" class="space-y-4 divide-y divide-[#E0E0D7] lg:space-y-6">
					{% for item in fields.list %}
						<div class="overflow-hidden pb-4 last:pb-0 lg:pb-6">
							<button
								@click="toggle('faq-{{ loop.index }}')"
								class="w-full flex items-center gap-4 justify-between text-left"
								:aria-expanded="isActive('faq-{{ loop.index }}')"
							>
                                {% if fields.numbered %}
                                    <span class="hidden lg:block text-[18px] font-semibold text-green-dark w-10 shrink-0">{{ '%02d'|format(loop.index) }}</span>
                                {% endif %}
                                <span class="{{ html_classes('text-h3 flex-1 pr-6.5 text-green-default', { 'md:text-[22px] md:font-bold md:leading-tight lg:text-right': fields.numbered }) }}">{{ item.title }}</span>
						<div class="relative size-6 shrink-0">
									<!-- Horizontal line (always visible) -->
									<span
										class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-4 h-0.5 bg-dark-text transition-transform duration-300"
										:class="{ 'rotate-0': !isActive('faq-{{ loop.index }}'), 'rotate-180': isActive('faq-{{ loop.index }}') }"
									></span>
									<!-- Vertical line (rotates to horizontal when open) -->
									<span
										class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-4 h-0.5 bg-dark-text transition-transform duration-300 origin-center"
										:class="{ 'rotate-90': !isActive('faq-{{ loop.index }}'), 'rotate-0': isActive('faq-{{ loop.index }}') }"
									></span>
								</div>
							</button>
							<div
								x-show="isActive('faq-{{ loop.index }}')"
								x-collapse
							>
								<div class="text-body-13 text-green-dark pt-2 md:text-[16px] md:pt-4 lg:text-[18px]">
									{{ item.text }}
								</div>
							</div>
						</div>
					{% endfor %}
				</div>
			{% endif %}

			{# Schema.org FAQ structured data #}
			{{ fields.list|faq_schema|raw }}
		{% endblock %}
	{% endembed %}
</section>
