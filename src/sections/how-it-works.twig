<section>
	{% embed "../layouts/container.twig" %}
		{% block content %}
			<div class="grid grid-cols-12 gap-6 auto-rows-auto">
				{% if fields.title %}
					<h2 class="text-h2 col-span-7 text-green-default">{{ fields.title }}</h2>
				{% endif %}

				{% if fields.image %}
					<div class="col-span-5 row-span-3 h-full relative">
						<img src="{{ fields.image.src }}" alt="{{ fields.image.alt|default('Як це працює') }}" class="size-full object-cover absolute inset-0">
					</div>
				{% endif %}

				{% if fields.list %}
					{% for item in fields.list %}
						<div class="flex flex-col gap-3 text-green-dark pb-4 border-b border-[#C7C7C7] pl-1.5 {{ html_classes({
                            'col-span-7': loop.index < 3,
                            'col-span-full': loop.index >= 3,
                        }) }}">
							<h3>
								<span class="text-[16px] mr-2">0{{ loop.index }}</span><span class="text-h3">{{ item.title }}</span>
							</h3>
							<p class="text-body-13">{{ item.text }}</p>
						</div>
					{% endfor %}
				{% endif %}
			</div>
		{% endblock %}
	{% endembed %}
</section>
