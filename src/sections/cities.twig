<section class="text-dark-text bg-[#E5EFDE] py-10">
	{% embed "../layouts/container.twig" %}
		{% block content %}
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12">
				<div class="lg:col-span-7 flex flex-col justify-center lg:pb-7 lg:pt-20">
				{% if fields.title %}
					<div class="mb-6">
						<h2 class="text-h2 mb-2 md:text-[40px] md:leading-normal">{{ fields.title }}</h2>
						{% if fields.text %}
							<p class="text-body-15 md:text-[16px]">{{ fields.text }}</p>
						{% endif %}
					</div>
				{% endif %}

				{% if fields.cities %}
					<ul class="flex flex-wrap gap-3 mb-6">
						{% set widthPattern = [
							'flex-[1_1_28%]',
							'flex-[1_1_35%]',
							'flex-[1_1_25%]',
							'flex-[1_1_30%]',
							'flex-[1_1_32%]',
							'flex-[1_1_27%]',
							'flex-[1_1_33%]',
							'flex-[1_1_29%]',
							'flex-[1_1_26%]'
						] %}
						{% for city in fields.cities %}
							{% set widthClass = widthPattern[loop.index0 % widthPattern|length] %}
							<li class="{{ widthClass }} lg:flex-1 lg:min-w-60">
								{% if city.url %}
									<a href="{{ city.url }}" class="block bg-green-easy text-white rounded-2xl px-4 py-4.5 text-center text-h4 lg:px-20">
										{{ city.text }}
									</a>
								{% elseif city is iterable %}
									<div class="block bg-green-easy text-white  rounded-2xl px-4 py-4.5 text-center text-h4">
										{{ city.text }}
									</div>
								{% else %}
									<div class="block bg-green-easy text-white  rounded-2xl px-4 py-4.5 text-center text-h4">
										{{ city }}
									</div>
								{% endif %}
							</li>
						{% endfor %}
      	              {% if fields.button %}
      	                  <div class="flex justify-center flex-1 min-w-max lg:w-auto lg:flex-1">
      	                      {% include '../components/button.twig' with {
      	                          text: fields.button.text,
      	                          link: fields.button.link,
      	                          variant: fields.button.variant|default('green'),
      	                          size: fields.button.size|default('lg'),
      	                          target: fields.button.target|default('_self'),
      	                          showIcon: fields.button.showIcon|default(false)
      	                      } %}
      	                  </div>
      	              {% endif %}
					</ul>
				{% endif %}
				</div>
				{% if fields.img %}
					<div class="hidden overflow-hidden -my-10 -mr-30 lg:block lg:col-span-5 relative">
            <div class="absolute inset-y-0 left-0 w-[50vw]">
              <img src="{{fields.img.src}}" alt="{{fields.img.alt}}" class="w-full h-full object-cover"/>
            </div>
          </div>
				{% endif %}
			</div>
		{% endblock %}
	{% endembed %}
	
</section>
