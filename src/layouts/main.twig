<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8"/>
		<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
		<title>{{ title | default('Vite + Twig + Tailwind Boilerplate') }}</title>
		<link rel="stylesheet" href="/src/assets/styles/main.css">
		<script type="module" src="/src/assets/js/app.js"></script>
	</head>
	<body class="min-h-screen">
		{% include "header.twig" %}
		<main class="flex flex-col gap-12 pb-12 pt-2.5 md:pt-4 lg:gap-25 lg:pt-8 lg:pb-25 bg-background">
			{% block content %}
				<div class="max-w-4xl mx-auto">
					<h1 class="text-4xl font-bold mb-6">Welcome to Your Boilerplate</h1>
					<p class="text-lg text-gray-600 mb-4">This is a minimal Vite + Twig + Tailwind CSS starter template.</p>
					<p class="text-gray-600">Start building by editing the files in the
						<code class="bg-gray-200 px-2 py-1 rounded">src/</code>
						directory.</p>
				</div>
			{% endblock %}
		</main>
		{% include "footer.twig" %}
	</body>
</html>
