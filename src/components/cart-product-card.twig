{% set unitPrice = product.price|replace({' zł': '', 'zł': ''})|trim %}

{# Mobile / tablet: stacked card #}
<div class="flex lg:hidden gap-3 h-34 sm:h-44 md:h-48 pb-4 items-center justify-between overflow-hidden border-b border-[#E0E0D7]">
	<img src="{{ product.img.src }}" alt="{{ product.img.alt }}" class="h-full object-cover aspect-11/12">
	<div class="flex flex-col justify-between size-full">
		<div class="flex flex-col ">
			<div class="flex justify-between">
				{% if product.title %}
					<h2 class="text-h3 font-bold text-[#1e462f]">
						{{ product.title }}
					</h2>
				{% endif %}
				<button class="group h-5 w-5">
					<svg class="h-5 w-5 stroke-current text-[#6D9586] group-active:text-green-dark transition-colors" viewbox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
						<path d="M14.125 5.87521L5.87542 14.1248" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
						<path d="M14.125 14.1248L5.87542 5.87521" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
					</svg>
				</button>
			</div>
			{% if product.description  %}
				<p class="text-body-13 text-[#426E59]">
					{{ product.description }}
				</p>
			{% endif %}
		</div>
		<div class="flex justify-between items-center">
			{% if product.price  %}
				<span class="text-h3">
					{{ product.price }}
				</span>
			{% endif %}
			<div class="flex items-center justify-between w-28.75">
				<button class="flex h-9 w-9 items-center justify-center cursor-pointer rounded-xl border border-green-easy group active:bg-green-easy hover:bg-white transition-colors">
					<svg class="h-5 w-5 stroke-current text-green-easy group-active:text-white transition-colors" viewbox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
						<path d="M15.833 10H4.16634" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
					</svg>
				</button>
				<span class="text-h3">{{ product.quantity|default(1) }}</span>
				<button class="flex h-9 w-9 items-center justify-center cursor-pointer rounded-xl border border-green-easy group active:bg-green-easy hover:bg-white transition-colors">
					<svg class="h-5 w-5 stroke-current text-green-easy group-active:text-white transition-colors" viewbox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
						<path d="M10 4.16666V15.8333" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
						<path d="M15.833 10H4.16634" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
					</svg>
				</button>
			</div>
		</div>
	</div>
</div>

{# Desktop: single horizontal row #}
<div class="hidden lg:flex gap-6 pb-4 items-stretch border-b border-[#E0E0D7]">
	<img src="{{ product.img.src }}" alt="{{ product.img.alt }}" class="h-37 w-35 shrink-0 object-cover border border-[#F7F7F6]">
	<div class="flex flex-1 items-center justify-between pr-3">
		<div class="flex flex-col gap-1 w-84">
			{% if product.title %}
				<h2 class="text-[22px] font-bold leading-tight text-green-default">{{ product.title }}</h2>
			{% endif %}
			{% if product.description %}
				<p class="text-[14px] leading-6 text-[#426E59]">{{ product.description }}</p>
			{% endif %}
		</div>
		<div class="flex items-center gap-2.5 h-13 px-4 py-1 rounded-2xl border border-[#E0E0D7] bg-background">
			<button class="group flex h-5 w-5 items-center justify-center cursor-pointer">
				<svg class="h-5 w-5 stroke-current text-green-easy group-active:text-green-dark transition-colors" viewbox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
					<path d="M15.833 10H4.16634" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
				</svg>
			</button>
			<span class="w-8 text-center text-[22px] font-bold text-[#222e34]">{{ product.quantity|default(1) }}</span>
			<button class="group flex h-5 w-5 items-center justify-center cursor-pointer">
				<svg class="h-5 w-5 stroke-current text-green-easy group-active:text-green-dark transition-colors" viewbox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
					<path d="M10 4.16666V15.8333" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
					<path d="M15.833 10H4.16634" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
				</svg>
			</button>
		</div>
		<span class="w-21 text-center text-[22px] font-bold text-gray-1">{{ product.price }}</span>
		<span class="w-21 text-center text-[22px] font-bold text-gray-1">{{ unitPrice * product.quantity|default(1) }} zł</span>
		<button class="group flex h-6 w-6 items-center justify-center cursor-pointer">
			<svg class="h-6 w-6 stroke-current text-[#6D9586] group-active:text-green-dark transition-colors" viewbox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
				<path d="M14.125 5.87521L5.87542 14.1248" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
				<path d="M14.125 14.1248L5.87542 5.87521" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
			</svg>
		</button>
	</div>
</div>
