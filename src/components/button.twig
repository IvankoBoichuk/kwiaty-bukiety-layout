{% set variant = variant|default('primary') %}
{% set size = size|default('md') %}
{% set showIcon = showIcon|default(true) %}

{% set variantClasses = {
	'primary': 'bg-primary text-white hover:opacity-80',
	'secondary': 'bg-white text-primary border-2 border-primary hover:bg-primary hover:text-white',
	'outline': 'bg-transparent text-primary border-2 border-primary hover:bg-primary hover:text-white',
	'ghost': 'bg-transparent text-primary hover:bg-primary/10'
} %}

{% set sizeClasses = {
	'sm': 'px-2.5 py-1 text-sm gap-1',
	'md': 'px-3 py-1.5 text-base gap-1.5',
	'lg': 'px-4 py-2 text-lg gap-2'
} %}

{% set iconSizes = {
	'sm': '24',
	'md': '32',
	'lg': '40'
} %}

<a href="{{ link }}" target="{{ target }}" class="{{ html_classes('inline-flex items-center rounded-2xl transition-all duration-200', variantClasses[variant], sizeClasses[size]) }}">
	<span>{{ text }}</span>
	{% if showIcon %}
		{% set iconSize = iconSizes[size] %}
		<svg class="flex-none" width="{{ iconSize }}" height="{{ iconSize }}" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
			<rect width="32" height="32" rx="16" fill="currentColor" fill-opacity="0.15"/>
			<path d="M15.9718 9.19928H22.8007V15.9718" stroke="currentColor" stroke-width="2" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
			<path d="M9.19934 22.8007L22.8008 9.19928" stroke="currentColor" stroke-width="2" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
		</svg>
	{% endif %}
</a>