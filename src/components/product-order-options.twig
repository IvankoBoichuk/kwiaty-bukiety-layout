<div class="flex flex-col gap-8 lg:gap-6">

	<div class="flex flex-col gap-8 lg:flex-row lg:gap-6">
		{# Date dostawy #}
		<div class="flex-1 flex flex-col gap-3">
			<div class="flex items-center gap-2 text-green-default">
				<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
				<path d="M15.8333 3.33301H4.16667C3.24619 3.33301 2.5 4.0792 2.5 4.99967V16.6663C2.5 17.5868 3.24619 18.333 4.16667 18.333H15.8333C16.7538 18.333 17.5 17.5868 17.5 16.6663V4.99967C17.5 4.0792 16.7538 3.33301 15.8333 3.33301Z" stroke="#0C4A2C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
				<path d="M13.3333 1.66699V5.00033" stroke="#0C4A2C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
				<path d="M6.66675 1.66699V5.00033" stroke="#0C4A2C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
				<path d="M2.5 8.33301H17.5" stroke="#0C4A2C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
				</svg>

				<span class="text-body-14 md:text-[16px] lg:font-semibold">Date dostawy</span>
			</div>

			<div class="flex gap-1.5">
				<button 
					type="button"
					class="delivery-date-option h-8 md:h-11 flex-1 px-3 py-1.5 bg-white border border-[#E0E0D7] text-green-dark! text-body-13 md:text-[15px] rounded-xl transition-all active:bg-green-easy active:border-green-easy active:shadow active:text-white! flex items-center justify-center gap-1"
					data-date-option="today"
				>
					Dzisiaj
				</button>
				<button 
					type="button"
					class="delivery-date-option h-8 md:h-11 flex-1 px-3 py-1.5 bg-white border border-[#E0E0D7] text-green-dark! text-body-13 md:text-[15px] rounded-xl transition-all active:bg-green-easy active:border-green-easy active:shadow active:text-white! flex items-center justify-center gap-1"
					data-date-option="tomorrow"
				>
					Jutro
				</button>
				<button 
				  type="button"
				  class="group delivery-date-option h-8 md:h-11 delivery-date-custom flex-none px-3 py-2 bg-white border border-[#E0E0D7] text-green-dark! text-body-13 md:text-[15px] rounded-xl transition-all active:bg-green-easy active:border-green-easy active:shadow active:text-white! flex items-center justify-center gap-1"
				  data-date-option="custom"
				>
				  <span class="delivery-date-label">Inna data</span>
				  <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
				    <path 
				      d="M7.5 15L12.5 10L7.5 5" 
				      class="stroke-gray-3 group-active:stroke-white transition-colors" 
				      stroke-width="1.5" 
				      stroke-linecap="round" 
				      stroke-linejoin="round"
				    />
				  </svg>
				  <input 
				    type="date" 
				    class="delivery-date-input hidden absolute opacity-0 pointer-events-none"
				    data-date-input
				    min="{{ 'now'|date('Y-m-d') }}"
				  >
				</button>
			</div>
		</div>

		{# Czas dostawy #}
		<div class="flex-1 flex flex-col gap-3">
			<div class="flex items-center gap-2 text-green-default">
				<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
				<path d="M10.0001 18.3337C14.6025 18.3337 18.3334 14.6027 18.3334 10.0003C18.3334 5.39795 14.6025 1.66699 10.0001 1.66699C5.39771 1.66699 1.66675 5.39795 1.66675 10.0003C1.66675 14.6027 5.39771 18.3337 10.0001 18.3337Z" stroke="#0C4A2C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
				<path d="M10 5V10L13.3333 11.6667" stroke="#0C4A2C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
				</svg>

				<span class="text-body-14 md:text-[16px] lg:font-semibold">Czas dostawy</span>
			</div>

			<div class="flex gap-2 flex-wrap">
				<button 
					type="button"
					class="delivery-time-option flex-1 px-4 py-2 h-8 md:h-11 bg-white border border-[#E0E0D7] text-green-dark! text-body-13 md:text-[15px] rounded-xl transition-all active:bg-green-easy active:shadow active:text-white! flex items-center justify-center gap-1"
					data-time-slot="08-12"
				>
					08-12
				</button>
				<button 
					type="button"
					class="delivery-time-option flex-1 px-4 py-2 h-8 md:h-11 bg-white border border-[#E0E0D7] text-green-dark! text-body-13 md:text-[15px] rounded-xl transition-all active:bg-green-easy active:shadow active:text-white! flex items-center justify-center gap-1"
					data-time-slot="12-15"
				>
					12-15
				</button>
				<button 
					type="button"
					class="delivery-time-option flex-1 px-4 py-2 h-8 md:h-11 bg-white border border-[#E0E0D7] text-green-dark! text-body-13 md:text-[15px] rounded-xl transition-all active:bg-green-easy active:shadow active:text-white! flex items-center justify-center gap-1"
					data-time-slot="15-18"
				>
					15-18
				</button>
				<button 
					type="button"
					class="delivery-time-option flex-1 px-4 py-2 h-8 md:h-11 bg-white border border-[#E0E0D7] text-green-dark! text-body-13 md:text-[15px] rounded-xl transition-all active:bg-green-easy active:shadow active:text-white! flex items-center justify-center gap-1"
					data-time-slot="18-21"
				>
					18-21
				</button>
			</div>
		</div>
	</div>

	{# Tresc bileciku #}
	<div class="flex flex-col gap-3">
		<div class="flex items-center gap-2 text-green-default">
			<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
			<path d="M17.5 9.58336C17.5029 10.6832 17.2459 11.7683 16.75 12.75C16.162 13.9265 15.2581 14.916 14.1395 15.6078C13.021 16.2995 11.7319 16.6662 10.4167 16.6667C9.31678 16.6696 8.23176 16.4126 7.25 15.9167L2.5 17.5L4.08333 12.75C3.58744 11.7683 3.33047 10.6832 3.33333 9.58336C3.33384 8.26815 3.70051 6.97907 4.39227 5.86048C5.08402 4.7419 6.07355 3.838 7.25 3.25002C8.23176 2.75413 9.31678 2.49716 10.4167 2.50002H10.8333C12.5703 2.59585 14.2109 3.32899 15.441 4.55907C16.671 5.78915 17.4042 7.42973 17.5 9.16669V9.58336Z" stroke="#0C4A2C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
			</svg>

			<span class="text-body-14 md:text-[16px] lg:font-semibold">Tresc bileciku</span>
		</div>

		<textarea 
			class="w-full min-h-23 px-3 py-2.5 bg-transparent border border-[#C7C7C7] bg-white rounded-xl text-body-13 text-green-default placeholder:text-[#404844] focus:outline-none focus:border-green-easy resize-none md:text-[16px] lg:min-h-17"
			placeholder="Залишай порожнім, якщо не потрібно відкритки"
			name="card-message"
		></textarea>
	</div>
</div>
