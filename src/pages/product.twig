{% extends "./layouts/product.twig" %}

{% block content %}
	{# Resolve active variation price for the cart bar total #}
	{% set cartTotal = product.variations|first.price %}
	{% for v in product.variations if v.active %}{% set cartTotal = v.price %}{% endfor %}

	<section class="bg-background">
        <div class="px-3 sm:px-8 lg:px-29.25 w-full mx-auto">
            <div class="lg:grid lg:grid-cols-2 lg:gap-x-8 lg:items-start">

                {# Product Gallery (left / top) #}
                <div class="-mx-3 sm:-mx-8 lg:mx-0 mb-1 lg:mb-0 lg:col-start-1 lg:row-start-1">
                    {% include "components/product-gallery.twig" with {
                        images: product.gallery,
                        badges: product.badges|default([])
                    } %}
                </div>

                {# Product info (right column, spans both rows on desktop) #}
                <div class="flex flex-col lg:col-start-2 lg:row-start-1 lg:row-span-2">
                    {# Badges (desktop only — shown over the image on smaller screens) #}
                    {% if product.badges %}
                        <div class="hidden lg:flex flex-wrap gap-1.5 mb-3">
                            {% for badge in product.badges %}
                                <span class="{{ html_classes('flex items-center px-4 py-2 bg-purple text-white text-[13px] leading-4 uppercase rounded-full whitespace-nowrap', { 'bg-purple-dark': badge == 'Dostawa Gratis' }) }}">
                                    {{ badge }}
                                </span>
                            {% endfor %}
                        </div>
                    {% endif %}

                    {# Product Title #}
                    <h1 class="text-[22px] leading-5.75 font-extrabold mb-4 text-green-default md:text-[32px] md:leading-tight md:normal-case md:mb-5.25 md:py-2 md:font-semibold lg:font-bold lg:py-0">
                        {{ product.title }}
                    </h1>

                    {# Product Variations #}
                    <div class="mb-8 lg:mb-6">
                        <div class="flex items-center gap-2 text-green-default mb-3">
                          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
													<path d="M15 6.66699L18.3333 10.0003L15 13.3337" stroke="#0C4A2C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
													<path d="M5.00008 6.66699L1.66675 10.0003L5.00008 13.3337" stroke="#0C4A2C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
													<path d="M1.66675 10H18.3334" stroke="#0C4A2C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
													</svg>

                          <span class="text-body-14 md:text-[16px] lg:font-semibold">Wielkość bukietu</span>
                        </div>
                        {% include "components/product-variations.twig" with {variations: product.variations} %}
                    </div>

                    {# Order Options #}
                    <div class="mb-12 lg:mb-8">
                        {% include "components/product-order-options.twig" %}
                    </div>

                    {# Product Additions #}
                    <div class="mb-8 md:mb-25 lg:mb-6">
                        {% include "components/product-additions.twig" with {additions: product.additions} %}
                    </div>

                    {# Add to cart (desktop) #}
                    <div class="hidden lg:block">
                        {% include "components/product-cart-bar.twig" with {total: cartTotal, quantity: 1} %}
                    </div>
                </div>

                {# Description + Reviews (left column, below gallery on desktop) #}
                <div class="flex flex-col lg:col-start-1 lg:row-start-2">
                    {# Product Description #}
                    <div class="mb-6 md:mb-3 lg:mb-10">
                        {% include "components/product-description.twig" with {description: product.description} %}
                    </div>

                    {# Product Reviews #}
                    <div>
                        {% include "components/product-reviews.twig" with {reviews: product.reviews} %}
                    </div>
                </div>

            </div>
        </div>

	</section>

    {# Similar Products #}
    {% if similarProducts %}
        {% include "sections/similar-products.twig" with {fields: similarProducts} %}
    {% endif %}

    {# FAQ #}
    {% if faq %}
        {% include "sections/faq.twig" with {fields: faq|merge({numbered: true})} %}
    {% endif %}

    {# Guarantees #}
    {% if guarantees %}
        {% include "sections/guarantees.twig" with {fields: guarantees} %}
    {% endif %}

    {# SEO text #}
    {% if info %}
        {% include "sections/category-info.twig" with {info: info} %}
    {% endif %}
{% endblock %}
